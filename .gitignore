# Ignorar carpeta de datos
1. DATOS/
DATOS/

# Blindaje adicional para paquetes de datos crudos.
# Esto evita subir ZIP u otros contenedores pesados aunque en el futuro
# se relajen reglas sobre subcarpetas de 1. DATOS/ para compartir
# metadatos, diccionarios o documentacion del proyecto.
1. DATOS/**/*.zip
1. DATOS/**/*.7z
1. DATOS/**/*.rar
1. DATOS/**/*.tar
1. DATOS/**/*.tar.gz
1. DATOS/**/*.gz
1. DATOS/**/*.bz2
1. DATOS/**/*.xz

# Temporales de procesamiento
2. PROCESAMIENTO/_tmp_unzip/
2. PROCESAMIENTO/_tmp_macro_base_eam/
2. PROCESAMIENTO/_tmp_*/

# Macrobase pesada como artefacto derivado de datos
4. RESULTADOS/macro_base_eam.rds

# Archivos locales de R/RStudio
.Rhistory
.RData
.Ruserdata
.Rproj.user/

# Temporales comunes de sistema y editores
*.tmp
*.temp
*.bak
*~
\#*
.DS_Store
Thumbs.db
